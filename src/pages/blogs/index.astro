---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import BackToHome from '../../components/BackToHome.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Render each post to get reading time from remarkPluginFrontmatter
const postsWithReadingTime = await Promise.all(
	posts.map(async (post) => {
		const { remarkPluginFrontmatter } = await render(post);
		return { ...post, minutesRead: remarkPluginFrontmatter?.minutesRead };
	})
);

const title = "Blog - Wannes";
const description = "Thoughts on software engineering, .NET, Rust, Elixir, and building scalable systems.";
---

<BaseLayout title={title} description={description}>
	<main class="flex-1">
		<div class="ts-wrap">
			<header class="ts-header">
				<p class="ts-eyebrow"><span class="ts-eyebrow__sq" aria-hidden="true"></span>writing</p>
				<h1 class="ts-header__title">Posts</h1>
				<p class="ts-header__subtitle">
					Thoughts on software engineering, .NET, Rust, Elixir, and building scalable systems.
				</p>
			</header>

			{postsWithReadingTime.length === 0 ? (
				<p class="ts-empty">No posts yet.</p>
			) : (
				<section class="ts-posts" aria-label="Blog posts">
					{postsWithReadingTime.map((post) => (
						<BlogCard
							title={post.data.title}
							description={post.data.description}
							pubDate={post.data.pubDate}
							href={`/blogs/${post.id}`}
							minutesRead={post.minutesRead}
						/>
					))}
				</section>
			)}

			<BackToHome />
		</div>
	</main>
</BaseLayout>

<style>
	.ts-wrap {
		max-width: var(--ts-maxw);
		margin: 0 auto;
		padding: 0 24px;
	}

	.ts-header {
		padding: clamp(48px, 8vw, 80px) 0 clamp(28px, 4vw, 40px);
	}

	.ts-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		font-family: var(--ts-font-mono);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ts-muted);
		margin: 0 0 16px 0;
	}
	.ts-eyebrow__sq {
		width: 7px;
		height: 7px;
		background: var(--ts-primary);
		flex: none;
	}

	.ts-header__title {
		font-family: var(--ts-font-heading);
		font-weight: 700;
		font-size: clamp(40px, 7vw, 64px);
		line-height: 1.04;
		letter-spacing: -0.02em;
		margin: 0;
		color: var(--ts-foreground);
	}

	.ts-header__subtitle {
		max-width: 62ch;
		margin: 18px 0 0 0;
		font-family: var(--ts-font-body);
		font-size: 18px;
		line-height: 1.6;
		font-weight: 400;
		color: var(--ts-muted);
	}

	.ts-posts {
		padding-top: clamp(8px, 2vw, 16px);
	}

	.ts-empty {
		font-family: var(--ts-font-body);
		font-size: 17px;
		color: var(--ts-muted);
		padding: 24px 0;
	}
</style>
