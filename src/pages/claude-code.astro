---
import BaseLayout from "../layouts/BaseLayout.astro";
import BackToHome from "../components/BackToHome.astro";

const title = "Claude Code Tips - Wannes Gennar";
const description = "Things I use daily that most people miss, overlook, or don't know about Claude Code.";

function md(text: string): string {
    return text.replace(/`([^`]+)`/g, '<code class="text-purple-700 dark:text-purple-300 bg-gray-100 dark:bg-gray-800 px-1 py-0.5 rounded text-xs font-mono">$1</code>');
}

type Category = "Workflow" | "Slash Commands" | "Context" | "Hooks" | "Tools" | "Cost";

interface Tip {
    id: number;
    category: Category;
    title: string;
    body: string;
    code?: string;
    note?: string;
    docs?: string;
    docsLabel?: string;
    items?: Array<{ label: string; description: string }>;
}

const categoryColors: Record<Category, { border: string; badge: string }> = {
	"Workflow":       { border: "from-blue-500 to-blue-600",     badge: "bg-blue-100 dark:bg-blue-950/40 text-blue-700 dark:text-blue-400 border border-blue-200 dark:border-blue-800" },
    "Slash Commands": { border: "from-purple-500 to-purple-600", badge: "bg-purple-100 dark:bg-purple-950/40 text-purple-700 dark:text-purple-400 border border-purple-200 dark:border-purple-800" },
    "Context":        { border: "from-teal-500 to-cyan-500",     badge: "bg-teal-100 dark:bg-teal-950/40 text-teal-700 dark:text-teal-400 border border-teal-200 dark:border-teal-800" },
    "Hooks":          { border: "from-orange-500 to-amber-500",  badge: "bg-orange-100 dark:bg-orange-950/40 text-orange-700 dark:text-orange-400 border border-orange-200 dark:border-orange-800" },
    "Tools":          { border: "from-pink-500 to-rose-500",     badge: "bg-pink-100 dark:bg-pink-950/40 text-pink-700 dark:text-pink-400 border border-pink-200 dark:border-pink-800" },
	"Cost":           { border: "from-yellow-500 to-yellow-600",     badge: "bg-yellow-100 dark:bg-yellow-950/40 text-yellow-700 dark:text-yellow-400 border border-yellow-200 dark:border-yellow-800" },
};

const tips: Tip[] = [
    // ── Context ──────────────────────────────────────────────────────────────
    {
        id: 1,
        category: "Context",
        title: "CLAUDE.md persists your instructions across every session",
        body: "Claude Code reads `CLAUDE.md` from your project root — and from your home directory for global settings — at the start of every session. Coding conventions, architecture decisions, things Claude should never do: write them once and they're there every time. You stop repeating yourself; Claude starts with the right mental model from message one.",
        note: "You can have both a global `~/.claude/CLAUDE.md` and a project-level one. Both load — project instructions take precedence.",
        docs: "https://docs.anthropic.com/en/docs/claude-code/memory",
        docsLabel: "Memory docs",
    },
    {
        id: 2,
        category: "Context",
        title: "A long CLAUDE.md is a diluted CLAUDE.md",
        body: "`CLAUDE.md` gets inserted into the context window at session start. The longer it is, the more working memory it consumes — and the more likely important instructions get buried under irrelevant ones. Keep it to things that are genuinely non-obvious or would materially change Claude's behaviour. Move rarely-needed rules into scoped rule files instead.",
    },
    {
        id: 3,
        category: "Context",
        title: "Use @ to split a large CLAUDE.md into focused modules",
        body: "A `@path/to/file` reference inside `CLAUDE.md` inserts that file's content at that point — like an include directive. Use it to separate concerns: a top-level file that pulls in a coding-standards module, an architecture notes module, a \"never do this\" module. Each stays focused and easy to maintain independently.",
        code: `# .claude/CLAUDE.md
@.claude/standards/coding.md
@.claude/standards/architecture.md
@.claude/rules/never.md`,
    },
    {
        id: 4,
        category: "Context",
        title: "@ a file in conversation to pull it into context immediately",
        body: "Typing `@src/auth/middleware.ts` in your message tells Claude to read that file and include it in context right now — no separate read call needed. Useful when you know Claude needs to see a specific file rather than waiting for it to discover it through exploration. One caveat: large files eat context fast, so be deliberate.",
    },
    {
        id: 5,
        category: "Context",
        title: "Rule files don't fire on file creation — only on reads and edits",
        body: "Rule files are scoped to path patterns and only load when Claude reads or edits a matching file. The critical gotcha: creating a new file does not trigger rule files. If your `.cs` rule file defines how new classes should be structured, Claude won't see those rules when writing the file from scratch. This trips up experts and beginners alike.",
        note: "If your rules need to apply to newly created files, include them in `CLAUDE.md` or explicitly reference them in your prompt.",
        docs: "https://docs.anthropic.com/en/docs/claude-code/memory",
        docsLabel: "Rule files docs",
    },
    {
        id: 6,
        category: "Context",
        title: "Wrap large blocks of pasted context in XML tags",
        body: "When you paste in logs, specs, or reference code, wrapping them in XML tags helps Claude treat them as structured data rather than prose. Instructions stay cleanly separated from data, and Claude is less likely to conflate what's a guideline with what's content to process.",
        code: `<error_logs>
  [paste your logs here]
</error_logs>

<reference_implementation>
  [paste reference code here]
</reference_implementation>`,
    },

    // ── Slash Commands ────────────────────────────────────────────────────────
    {
        id: 7,
        category: "Slash Commands",
        title: "/compact summarises without losing your thread — and takes instructions",
        body: "Instead of opening a new session when context fills up, `/compact` compresses the full conversation into a tight summary and continues from there. What most people don't know: you can pass instructions to shape what it keeps — focus on specific modules, ignore noisy output, preserve key decisions. Almost always the right move over starting fresh.",
        code: "/compact keep focus on the auth module, discard the test output discussion",
    },
    {
        id: 8,
        category: "Slash Commands",
        title: "Avoid /clear — it destroys context and breaks external tools",
        body: "`/clear` wipes the entire conversation. Claude loses all accumulated context and reasoning, and tools like tokentelemetry that track session analytics lose their thread too. In almost every case `/compact` is what you actually want — it summarises rather than discards. Reserve `/clear` for when you're genuinely starting over on a completely unrelated task.",
    },
    {
        id: 9,
        category: "Slash Commands",
        title: "/rename so you can actually find sessions later",
        body: "Without a parameter, `/rename` generates a sensible name from context. With one, you make the session findable when you want to resume or reference it later. Unnamed sessions blur together fast — especially when you have several active at once.",
        code: "/rename payment-integration-fix",
    },
    {
        id: 10,
        category: "Slash Commands",
        title: "/color keeps parallel sessions from blurring together",
        body: "When you're running several Claude Code sessions at the same time, it's easy to lose track of which terminal is which. `/color` recolors a session's UI so you can identify it at a glance when switching between terminals.",
    },
    {
        id: 11,
        category: "Slash Commands",
        title: "/powerup is the best onboarding for new Claude Code users",
        body: "An interactive tutorial that walks through Claude Code's core features hands-on. Far better than pointing a new colleague at documentation — let `/powerup` orient them first, then they'll know what to look up and why.",
    },
    {
        id: 12,
        category: "Slash Commands",
        title: "/remote-control lets you manage Claude from your phone or another machine",
        body: "Generates a link you can open anywhere to view Claude's progress and send messages — without being at the machine running it. This is how Anthropic's own engineers manage long-running tasks from the train, between meetings, or away from their desk.",
    },
    {
        id: 13,
        category: "Slash Commands",
        title: "/desktop moves a session between the terminal and the desktop app",
        body: "Started a session in the terminal but want the desktop UI? `/desktop` opens it there — and vice versa. Both views stay in sync, so you can switch to whichever is more convenient without losing any context or history.",
    },
    {
        id: 14,
        category: "Slash Commands",
        title: "/handoff creates a self-contained briefing for handover or resumption",
        body: "Compresses the current conversation into a structured document: context, decisions made, what's left to do. Use it to hand off to a subagent, resume in a fresh session later, or bring a teammate up to speed on exactly where things stand.",
    },
    {
        id: 15,
        category: "Slash Commands",
        title: "/memory shows you exactly what Claude loads at session start",
        body: "Opens the current `CLAUDE.md` so you can inspect or edit what Claude reads every time a session begins. Useful for debugging unexpected behaviour, checking which instructions are active, or auditing what's been accumulating over time.",
    },

    // ── Workflow ──────────────────────────────────────────────────────────────
    {
        id: 16,
        category: "Workflow",
        title: "Escape interrupts Claude — and can roll back partial edits",
        body: "Pressing Escape mid-response stops Claude immediately. What many people miss: if Claude was partway through making file edits, it will offer to roll back those partial changes. Useful the moment you realise the direction is wrong, before it finishes.",
    },
    {
        id: 17,
        category: "Workflow",
        title: "Tab on a permission prompt lets you redirect, not just deny",
        body: "When Claude asks for permission, most people just hit yes or no. Pressing `Tab` on any option opens a text field for a clarifying note. This is most powerful on No: you can redirect Claude to a different tool, explain a constraint, or describe the approach you want instead — turning a flat denial into a useful redirect.",
    },
    {
        id: 18,
        category: "Workflow",
        title: "Let your formatter format — don't waste Claude's tokens on cosmetics",
        body: "By default Claude writes code and then tidies it up, spending tokens (your money) on cosmetic changes your formatter will overwrite anyway. If you have `cargo fmt`, `dotnet format`, or `prettier` in your toolchain, tell Claude in `CLAUDE.md` to skip formatting. It works faster, you pay less, and the formatter does the job better.",
        note: "Add something like `never manually format code — the project uses cargo fmt` to your `CLAUDE.md`.",
    },
    {
        id: 19,
        category: "Workflow",
        title: "Changing model or effort mid-conversation invalidates the cache",
        body: "Claude Code caches your conversation context so it doesn't re-send everything on every message. The moment you switch models or change the effort level, that cache is invalidated and you start paying full context cost again from scratch. Pick your model and effort at the start of a session, not mid-flight.",
    },
    {
        id: 20,
        category: "Workflow",
        title: "Git worktrees let Claude work on multiple features simultaneously",
        body: "Each worktree is an independent copy of your repo checked out on a different branch. Spin up a Claude Code session per worktree and you can have Claude working on separate features at the same time — no stash juggling, no accidental conflicts between sessions sharing a working directory.",
    },
    {
        id: 21,
        category: "Workflow",
        title: "Start with ! to run shell commands without leaving the session",
        body: "Typing `!git status` or `!cargo test` runs the command in your shell and streams the output directly into context. No need to switch terminal panes or paste output by hand. Great for quick checks without breaking your flow.",
        code: `!git status
!cargo test 2>&1 | tail -20`,
    },
    {
        id: 22,
        category: "Workflow",
        title: "Haiku, Sonnet, Opus, Fable — and when to reach for each",
        body: "Not all Claude models are suited to the same work. Use `/model` to switch and `/effort` to dial in thinking depth independently of the model.",
        items: [
            { label: "Haiku 4.5",  description: "Fast and cheap. Great for repetitive tasks, file operations, and bulk edits where reasoning depth doesn't matter." },
            { label: "Sonnet 4.6", description: "The daily driver. Balanced speed and capability — right for most coding tasks." },
            { label: "Opus 4.8",   description: "The heavyweight. Architecture decisions, tricky debugging, anything where deep reasoning matters." },
            { label: "Fable 5",    description: "Anthropic's newest. Strong at long-context understanding and multi-step planning." },
        ],
    },
    {
        id: 23,
        category: "Workflow",
        title: "Enable showThinkingSummaries to see how Claude reasons",
        body: "By default Claude Code collapses thinking and reasoning to keep output readable. Setting `showThinkingSummaries: true` in `settings.json` expands Claude's chain-of-thought inline — useful for debugging unexpected decisions or understanding why Claude took a particular path. You can also press `Ctrl+O` on any individual message to expand its reasoning on the spot without changing settings.",
        code: `// ~/.claude/settings.json  (user)  or  .claude/settings.json  (project)
{
  "showThinkingSummaries": true
}`,
    },
    {
        id: 24,
        category: "Workflow",
        title: "Orchestrators, subagents, and why the distinction matters",
        body: "Your main session is the orchestrator. It can spawn subagents to handle isolated, potentially noisy tasks — searching a large codebase, reading many files, running builds — and get back only a summary, keeping your context lean. Critical detail: subagents start cold with no memory of your session. Brief them like a smart colleague who just walked in: file paths, goal, constraints.",
    },
    {
        id: 25,
        category: "Workflow",
        title: "Use Claude's built-in task list to stay oriented on complex work",
        body: "For any task that spans multiple steps, ask Claude to maintain a task list. It tracks what's done, what's in progress, and what's left — giving you visibility at any point and keeping Claude from losing the thread on long-running work.",
    },

    // ── Hooks ─────────────────────────────────────────────────────────────────
    {
        id: 26,
        category: "Hooks",
        title: "Hooks are how you enforce security guardrails around tool calls",
        body: "Hooks intercept Claude's tool calls before they execute. Common patterns: block writes to production paths, require confirmation before destructive operations, strip secrets from context, prevent pushes to main. Each hook runs a shell command on a matching event — if it exits non-zero, the tool call is blocked.",
        docs: "https://docs.anthropic.com/en/docs/claude-code/hooks",
        docsLabel: "Hooks documentation",
    },
    {
        id: 27,
        category: "Hooks",
        title: "Hooks don't have to be serious — Pixel Agents is proof",
        body: "Hooks fire on tool events, which means any process can know exactly when Claude is doing something — and respond however it wants. Pixel Agents uses hook events to visualise an agent's activity in real time. A playful reminder that the mechanism isn't just for guardrails.",
        docs: "https://pixelagent.space/",
        docsLabel: "Pixel Agents",
    },

    // ── Tools ─────────────────────────────────────────────────────────────────
    {
        id: 28,
        category: "Tools",
        title: "Warp's Claude Code integration is worth it even if you skip Warp AI",
        body: "Warp is a terminal with deep AI integration — but even if you don't use Warp's own AI, the Claude Code-specific UX is genuinely useful: notifications when Claude needs your attention, better output rendering, and a developer experience tuned for AI-assisted workflows.",
        docs: "https://warp.dev",
        docsLabel: "Warp terminal",
    },
	{
		id: 29,
		category: "Tools",
		title: "tokentelemetry shows what your Claude sessions actually cost",
		body: "tokentelemetry is a third-party tool that reads your local Claude Code session data and gives you a detailed breakdown of token usage — including thinking tokens that aren't visible in the standard UI. Another reason to avoid `/clear`: it fragments the session data that tokentelemetry relies on to compute accurate analytics.",
		docs: "https://tokentelemetry.com/",
		docsLabel: "tokentelemetry.com",
	},
	{
		id: 30,
		category: "Cost",
		title: "Auto mode isn't free!",
		body: "Claude Code's 'auto' mode allows it to determine whether commands are safe or not, but it uses a classifier model to evaluate each command which consumes tokens; even `Write` commands! Use `allow` in your settings to whitelist read-only commands and run on `allow edits` if you know what commands will be executed ahead of time!",
		docs: "https://claude.com/blog/auto-mode",
		docsLabel: "Claude documentation",
	},
];

const categories = Object.keys(categoryColors) as Category[];
---

<BaseLayout title={title} description={description}>
    <main class="flex-1 px-6 py-16 md:py-24 relative overflow-hidden">
        <div class="max-w-5xl mx-auto">

            <!-- Header -->
            <div class="mb-16 space-y-6">
                <div class="flex items-end gap-4 flex-wrap">
                    <h1
                        class="text-5xl md:text-7xl font-black tracking-tight bg-gradient-to-br from-blue-500 via-blue-600 to-purple-600 dark:from-blue-400 dark:via-blue-500 dark:to-purple-500 bg-clip-text text-transparent animate-gradient drop-shadow-2xl"
                        style="font-family: 'Montserrat', sans-serif; background-size: 200% 200%;"
                    >
                        Claude Code Tips
                    </h1>
                    <span id="tip-count" class="mb-1 px-3 py-1 bg-gradient-to-r from-blue-500 to-purple-500 text-white text-sm rounded-lg font-bold shadow-md">
                        {tips.length} tips
                    </span>
                </div>
                <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 leading-relaxed max-w-3xl">
                    Things I use daily that most people miss, overlook, or just never knew existed.
                </p>
            </div>

            <!-- Category filter -->
            <div class="mb-10 flex flex-wrap gap-2">
                <button
                    data-filter="all"
                    class="filter-btn px-4 py-1.5 rounded-full text-sm font-semibold transition-all bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900"
                >
                    All
                </button>
                {categories.map((cat) => (
                    <button
                        data-filter={cat}
                        class={`filter-btn px-4 py-1.5 rounded-full text-sm font-semibold transition-all hover:scale-105 ${categoryColors[cat].badge}`}
                    >
                        {cat}
                    </button>
                ))}
            </div>

            <!-- Tips grid -->
            <div class="grid gap-6 md:grid-cols-2" id="tips-grid">
                {tips.map((tip) => {
                    const colors = categoryColors[tip.category];
                    return (
                        <article
                            data-category={tip.category}
                            class="tip-card group bg-white dark:bg-gray-900/50 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden hover:border-blue-500/50 dark:hover:border-blue-500/50 transition-all hover:shadow-xl hover:-translate-y-0.5"
                        >
                            <div class={`h-1 bg-gradient-to-r ${colors.border}`} />
                            <div class="p-6 space-y-4">

                                <!-- Category + id -->
                                <div class="flex items-center justify-between gap-3">
                                    <span class={`px-2.5 py-0.5 text-xs font-semibold rounded-full ${colors.badge}`}>
                                        {tip.category}
                                    </span>
                                    <span class="text-xs text-gray-400 dark:text-gray-600 font-mono">
                                        #{String(tip.id).padStart(2, "0")}
                                    </span>
                                </div>

                                <!-- Title -->
                                <h2
                                    class="text-xl font-bold text-gray-900 dark:text-gray-100 leading-snug"
                                    style="font-family: 'Montserrat', sans-serif;"
                                >
                                    {tip.title}
                                </h2>

                                <!-- Body -->
                                <p class="text-gray-700 dark:text-gray-300 leading-relaxed text-sm" set:html={md(tip.body)} />

                                <!-- Model list -->
                                {tip.items && (
                                    <ul class="space-y-2">
                                        {tip.items.map((item) => (
                                            <li class="flex gap-2.5 text-sm">
                                                <span class="font-mono font-bold text-gray-900 dark:text-gray-100 whitespace-nowrap">{item.label}</span>
                                                <span class="text-gray-600 dark:text-gray-400">{item.description}</span>
                                            </li>
                                        ))}
                                    </ul>
                                )}

                                <!-- Code block -->
                                {tip.code && (
                                    <pre class="text-xs bg-gray-100 dark:bg-gray-800/80 text-purple-700 dark:text-purple-300 rounded-lg p-4 overflow-x-auto font-mono border border-gray-200 dark:border-gray-700/60 whitespace-pre-wrap"><code>{tip.code}</code></pre>
                                )}

                                <!-- Note callout -->
                                {tip.note && (
                                    <div class="flex gap-2.5 bg-blue-50 dark:bg-blue-950/20 border border-blue-100 dark:border-blue-900/40 rounded-lg p-3.5">
                                        <svg class="w-4 h-4 text-blue-500 dark:text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        <p class="text-sm text-blue-800 dark:text-blue-300 leading-relaxed" set:html={md(tip.note!)} />
                                    </div>
                                )}

                                <!-- Docs link -->
                                {tip.docs && (
                                    <a
                                        href={tip.docs}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center gap-1.5 text-xs font-semibold text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                                    >
                                        {tip.docsLabel ?? "Documentation"}
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                        </svg>
                                    </a>
                                )}

                            </div>
                        </article>
                    );
                })}
            </div>

            <BackToHome />
        </div>
    </main>
</BaseLayout>

<script>
    const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const cards = document.querySelectorAll<HTMLElement>(".tip-card");
    const countEl = document.getElementById("tip-count");

    const activeBase = "bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900";
    const inactiveBase = "bg-white dark:bg-gray-900 text-gray-700 dark:text-gray-300 hover:scale-105";

    function updateCount() {
        const visible = [...cards].filter((c) => c.style.display !== "none").length;
        if (countEl) countEl.textContent = `${visible} tip${visible === 1 ? "" : "s"}`;
    }

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
            const filter = btn.dataset.filter!;

            buttons.forEach((b) => {
                const isActive = b.dataset.filter === filter;
                // preserve category colour classes; only toggle active state on "All"
                if (b.dataset.filter === "all") {
                    b.className = b.className
                        .replace(/bg-gray-\d+|dark:bg-gray-\d+|text-white|dark:text-gray-\d+/g, "")
                        .trim();
                    if (isActive) {
                        b.classList.add("bg-gray-900", "dark:bg-gray-100", "text-white", "dark:text-gray-900");
                    }
                } else {
                    b.style.opacity = isActive || filter === "all" ? "1" : "0.45";
                    b.style.transform = "";
                }
            });

            cards.forEach((card) => {
                const show = filter === "all" || card.dataset.category === filter;
                card.style.display = show ? "" : "none";
            });

            updateCount();
        });
    });
</script>
