---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Wannes — Software Engineer / AI Architect";
const description =
	"Full-stack .NET engineer working across Rust, Elixir, and the modern web. Founder of Elixus, building Meshum — the control plane for enterprise AI governance.";
---

<BaseLayout title={title} description={description}>
	<main class="hero">
		<div class="hero__inner">
			<h1 class="hero__name">Wannes</h1>
			<p class="hero__role">
				Software Engineer <span class="sep" aria-hidden="true">/</span> AI Architect
			</p>
			<p class="hero__tagline">
				Full-stack .NET engineer building systems that scale. Founder of
				<a href="https://www.elixus.be" target="_blank" rel="noopener noreferrer">Elixus</a>,
				currently building
				<a href="https://www.meshum.dev" target="_blank" rel="noopener noreferrer">Meshum</a>.
			</p>
			<hr class="gradient-rule" />
			<nav class="hero__links" aria-label="Elsewhere">
				<a class="link-btn" href="/claude-code">Claude Code</a>
				<a class="link-btn" href="https://www.elixus.be" target="_blank" rel="noopener noreferrer">Elixus</a>
				<a class="link-btn" href="https://github.com/dealloc" target="_blank" rel="noopener noreferrer">GitHub</a>
				<a class="link-btn" href="https://pathfinder.dealloc.be" target="_blank" rel="noopener noreferrer">TTRPG</a>
			</nav>
		</div>
	</main>
</BaseLayout>

<style>
	/* Centered hero that fills the viewport below the sticky nav */
	.hero {
		flex: 1;
		min-height: calc(100vh - 53px);
		min-height: calc(100dvh - 53px);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 48px 24px;
		text-align: center;
	}
	.hero__inner {
		max-width: 640px;
		width: 100%;
	}
	.hero__name {
		font-family: var(--ts-font-heading);
		font-weight: 700;
		font-size: clamp(56px, 13vw, 120px);
		line-height: 1;
		letter-spacing: -0.03em;
		margin: 0;
		color: var(--ts-foreground);
	}
	.hero__role {
		margin: 18px 0 0 0;
		font-size: clamp(16px, 2.2vw, 20px);
		color: var(--ts-muted);
		font-weight: 400;
	}
	.hero__role .sep {
		color: var(--ts-primary);
		margin: 0 10px;
		font-weight: 600;
	}
	.hero__tagline {
		margin: 20px auto 0;
		max-width: 46ch;
		font-size: clamp(15px, 1.8vw, 17px);
		line-height: 1.6;
		color: var(--ts-muted);
		font-weight: 300;
	}
	.hero__tagline a {
		color: var(--ts-accent-text);
		text-decoration: underline;
		text-decoration-color: oklch(62% 0.08 165 / 0.4);
		text-underline-offset: 3px;
		transition: color 160ms ease, text-decoration-color 160ms ease;
	}
	.hero__tagline a:hover {
		color: var(--ts-primary);
		text-decoration-color: var(--ts-primary);
	}
	/* Short centered gradient rule — the single brand-gradient moment */
	.gradient-rule {
		height: 2px;
		width: 80px;
		border: 0;
		margin: 32px auto 0;
		background: linear-gradient(90deg, var(--ts-primary), var(--ts-accent));
		border-radius: 2px;
	}
	.hero__links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 12px;
		margin-top: 28px;
	}
	.link-btn {
		display: inline-flex;
		align-items: center;
		padding: 9px 16px;
		border: 1px solid var(--ts-border);
		border-radius: 8px;
		background: var(--ts-surface);
		color: var(--ts-foreground);
		font-family: var(--ts-font-mono);
		font-size: 13px;
		font-weight: 500;
		text-decoration: none;
		transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
	}
	.link-btn:hover {
		border-color: var(--ts-primary);
		color: var(--ts-accent-text);
		background: oklch(62% 0.08 165 / 0.06);
	}
	.link-btn:focus-visible {
		outline: 2px solid var(--ts-primary);
		outline-offset: 3px;
	}

	@media (prefers-reduced-motion: reduce) {
		*, *::before, *::after {
			transition-duration: 0.01ms !important;
			animation-duration: 0.01ms !important;
		}
	}
</style>
