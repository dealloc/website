									<div class="flex flex-wrap justify-between gap-1">
										<span><span class="font-semibold text-gray-800 dark:text-gray-200">Wieni</span> — Internship, Full Stack Developer</span>
										<span>Feb – May 2017</span>
									</div>
									<div class="flex flex-wrap justify-between gap-1">
										<span><span class="font-semibold text-gray-800 dark:text-gray-200">HR Organiser</span> — Frontend Developer</span>
										<span>Jul – Aug 2017</span>
									</div>
								</div>
							</div>
						</div>

					</div>
				</section>

				<!-- Education -->
				<section class="space-y-6">
					<h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">
						Education
					</h2>
					<div class="space-y-4">

