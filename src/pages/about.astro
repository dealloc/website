---
import BaseLayout from "../layouts/BaseLayout.astro";
import BackToHome from "../components/BackToHome.astro";

const title = "About - Wannes Gennar";
const description = "Full-stack .NET engineer with expertise in Rust, Elixir, and modern web technologies. Founder of Elixus, creator of Meshum.";
---

<BaseLayout title={title} description={description}>
    <main class="flex-1 px-6 py-16 md:py-24 relative overflow-hidden">

        <div class="max-w-4xl mx-auto">
            <!-- Header Section -->
            <div class="mb-16 space-y-6">
                <h1 class="text-5xl md:text-7xl font-black tracking-tight bg-gradient-to-br from-blue-500 via-blue-600 to-purple-600 dark:from-blue-400 dark:via-blue-500 dark:to-purple-500 bg-clip-text text-transparent animate-gradient drop-shadow-2xl" style="font-family: 'Montserrat', sans-serif; background-size: 200% 200%;">
                    About Me
                </h1>
                <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 leading-relaxed max-w-3xl">
                    Full-stack engineer passionate about building scalable systems and elegant solutions.
                </p>
            </div>

            <!-- Main Content -->
            <div class="space-y-16">

                <!-- Bio Section -->
                <section class="space-y-6">
                    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">
                        Who I Am
                    </h2>
                    <div class="prose prose-lg max-w-none space-y-4">
                        <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
                            I'm a full-stack .NET consultant with a deep passion for exploring new technologies and building systems that scale.
                            My journey has taken me through the worlds of Rust, Elixir, and modern web development — always seeking the right tool for the job.
                            Outside of client work I teach C# and .NET at Erasmushogeschool Brussel, and I've been known to go deep on AI tooling at the intersection of engineering and autonomous agents.
                        </p>
                        <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
                            As the founder of <a href="https://www.elixus.be" target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:text-purple-600 dark:hover:text-purple-400 font-semibold transition-colors">Elixus</a>,
                            I focus on creating innovative solutions for real-world problems. Currently, I'm building
                            <a href="https://www.meshum.dev" target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:text-purple-600 dark:hover:text-purple-400 font-semibold transition-colors">Meshum</a>
                            — a unified knowledge layer that helps teams keep using their favorite tools while making everything searchable through AI agents.
                        </p>
                    </div>
                </section>

                <!-- Tech Stack -->
                <section class="space-y-6">
                    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">
                        Technologies & Expertise
                    </h2>
                    <div class="flex flex-wrap gap-3">
                        <span class="px-4 py-2 bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-lg font-semibold shadow-md">.NET</span>
                        <span class="px-4 py-2 bg-gradient-to-r from-purple-500 to-purple-600 text-white rounded-lg font-semibold shadow-md">Rust</span>
                        <span class="px-4 py-2 bg-gradient-to-r from-blue-600 to-purple-500 text-white rounded-lg font-semibold shadow-md">Elixir</span>
                        <span class="px-4 py-2 bg-gray-700 dark:bg-gray-600 text-white rounded-lg font-semibold shadow-md">TypeScript</span>
                        <span class="px-4 py-2 bg-gray-700 dark:bg-gray-600 text-white rounded-lg font-semibold shadow-md">PostgreSQL</span>
                        <span class="px-4 py-2 bg-gray-700 dark:bg-gray-600 text-white rounded-lg font-semibold shadow-md">Redis</span>
                        <span class="px-4 py-2 bg-gray-700 dark:bg-gray-600 text-white rounded-lg font-semibold shadow-md">React</span>
                        <span class="px-4 py-2 bg-gray-700 dark:bg-gray-600 text-white rounded-lg font-semibold shadow-md">Blazor</span>
                        <span class="px-4 py-2 bg-gray-700 dark:bg-gray-600 text-white rounded-lg font-semibold shadow-md">Azure</span>
                    </div>
                </section>

                <!-- Certifications -->
                <section class="space-y-6">
                    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">
                        Certifications
                    </h2>
                    <div class="space-y-4">
                        <div class="rounded-xl border border-orange-200 dark:border-orange-900/60 overflow-hidden shadow-lg">
                            <div class="h-1.5 bg-gradient-to-r from-orange-400 via-orange-500 to-amber-400"></div>
                            <div class="bg-orange-50/60 dark:bg-orange-950/20 p-8 pb-2">
                                <div class="flex items-start gap-4">
                                    <a href="https://www.credly.com/badges/bda72065-fca1-40b5-a61b-a2a29c735264/public_url" target="_blank" rel="noopener noreferrer" class="flex-shrink-0 group">
										<div data-iframe-width="150" data-iframe-height="270" data-share-badge-id="bda72065-fca1-40b5-a61b-a2a29c735264" data-share-badge-host="https://www.credly.com"></div>
										<script type="text/javascript" async src="//cdn.credly.com/assets/utilities/embed.js"></script>
                                    </a>
                                    <div class="flex-1 space-y-2">
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <span class="text-sm font-semibold text-orange-700 dark:text-orange-400">Anthropic</span>
                                            <span class="px-2.5 py-0.5 bg-gradient-to-r from-orange-500 to-amber-500 text-white text-xs rounded-md font-bold tracking-wide shadow-sm">CCAR-F</span>
                                            <span class="px-2.5 py-0.5 bg-orange-100 dark:bg-orange-900/40 text-orange-700 dark:text-orange-300 text-xs rounded-md font-semibold border border-orange-200 dark:border-orange-800">938 / 1000</span>
                                        </div>
                                        <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100">Claude Certified Architect – Foundations</h3>
                                        <a
                                            href="https://www.credly.com/badges/bda72065-fca1-40b5-a61b-a2a29c735264/public_url"
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="inline-flex items-center gap-1.5 text-sm text-orange-600 dark:text-orange-400 hover:text-orange-800 dark:hover:text-orange-300 font-semibold transition-colors"
                                        >
                                            Verify credential
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                            </svg>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Current Work -->
                <section class="space-y-6">
                    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">
                        Here's my current hyperfixation
                    </h2>
                    <div class="bg-gray-50 dark:bg-gray-900/50 rounded-xl p-8 border border-gray-200 dark:border-gray-800 space-y-4">
                        <div class="flex items-center gap-3">
                            <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100">FABKIT</h3>
                            <span class="px-3 py-1 bg-gradient-to-r from-blue-500 to-purple-500 text-white text-sm rounded-lg font-semibold">Featured</span>
                        </div>
                        <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
                            A community-driven toolbox for Flesh and Blood TCG players. Create custom cards with authentic fonts, symbols, and templates — export them as print-ready PNGs. Installable as a PWA, works entirely in the browser, no account needed.
                        </p>
                        <div class="flex gap-3 flex-wrap">
                            <a
                                href="https://fabkit.io"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white rounded-lg font-semibold transition-all hover:scale-105 hover:shadow-lg"
                            >
                                fabkit.io
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                            </a>
                            <a
                                href="https://github.com/fabkit/fabkit"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 px-6 py-3 bg-gray-100 dark:bg-gray-900 hover:bg-gray-200 dark:hover:bg-gray-800 rounded-lg font-semibold transition-all hover:scale-105 hover:shadow-lg"
                            >
                                <span class="bg-gradient-to-r from-gray-700 to-gray-600 dark:from-gray-300 dark:to-gray-400 bg-clip-text text-transparent">GitHub</span>
                            </a>
                        </div>
                    </div>
                </section>

				<!-- Experience -->
				<section class="space-y-6">
					<h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">
						Experience
					</h2>
					<div class="space-y-4">

						<!-- Twipe -->
						<div class="rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
							<div class="h-1 bg-gradient-to-r from-blue-500 to-purple-500"></div>
							<div class="p-6 space-y-3">
								<div class="flex flex-wrap items-start justify-between gap-2">
									<div class="space-y-1">
										<div class="flex items-center gap-2 flex-wrap">
											<h3 class="text-xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">Twipe</h3>
											<span class="px-2 py-0.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-xs rounded font-medium">via Euricom</span>
										</div>
										<p class="text-blue-600 dark:text-blue-400 font-semibold">Senior Backend Developer</p>
									</div>
									<span class="text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">Feb 2026 – Present</span>
								</div>
								<p class="text-gray-700 dark:text-gray-300 leading-relaxed">
									Backend development at Twipe, a digital publishing platform powering e-editions and reading apps for major media companies across Europe.
								</p>
								<div class="flex flex-wrap gap-2 pt-1">
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">.NET</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">C#</span>
								</div>
							</div>
						</div>

						<!-- Euricom internal -->
						<div class="rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
							<div class="h-1 bg-gradient-to-r from-blue-500 to-purple-500"></div>
							<div class="p-6 space-y-3">
								<div class="flex flex-wrap items-start justify-between gap-2">
									<div class="space-y-1">
										<h3 class="text-xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">Euricom</h3>
										<p class="text-blue-600 dark:text-blue-400 font-semibold">Software Consultant</p>
									</div>
									<span class="text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">Oct 2025 – Jan 2026</span>
								</div>
								<p class="text-gray-700 dark:text-gray-300 leading-relaxed">
									Rebuilt Euricom's internal sales dashboard from scratch after an intern-built version developed significant issues. Chose .NET Blazor Server with .NET Aspire and set up a full CI/CD pipeline deploying automatically to Azure container apps.
								</p>
								<div class="flex flex-wrap gap-2 pt-1">
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Blazor</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">.NET Aspire</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Azure</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Tailwind</span>
								</div>
							</div>
						</div>

						<!-- Agilitas -->
						<div class="rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
							<div class="h-1 bg-gradient-to-r from-blue-500 to-purple-500"></div>
							<div class="p-6 space-y-3">
								<div class="flex flex-wrap items-start justify-between gap-2">
									<div class="space-y-1">
										<div class="flex items-center gap-2 flex-wrap">
											<h3 class="text-xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">Agilitas Belgium</h3>
											<span class="px-2 py-0.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-xs rounded font-medium">via Euricom</span>
										</div>
										<p class="text-blue-600 dark:text-blue-400 font-semibold">Lead Developer</p>
									</div>
									<span class="text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">Jul 2022 – Sep 2024</span>
								</div>
								<p class="text-gray-700 dark:text-gray-300 leading-relaxed">
									Brought in to migrate legacy PHP customer portals and rebuild all group websites across Agilitas and its European branches (Amplo, Ascento, Luba, E&A).
									Responsible for the full migration, stakeholder communication, and requirement gathering. When additional developers were onboarded, led the team and managed SCRUM processes.
									Built the new platform on Umbraco CMS with Azure monitoring and a job board featuring location-aware faceted search with Blazor Server.
								</p>
								<div class="flex flex-wrap gap-2 pt-1">
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">C#</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Umbraco</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">ASP.NET Core</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Blazor</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Azure</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">PHP</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Vue</span>
								</div>
							</div>
						</div>

						<!-- EHB -->
						<div class="rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
							<div class="h-1 bg-gradient-to-r from-blue-500 to-purple-500"></div>
							<div class="p-6 space-y-3">
								<div class="flex flex-wrap items-start justify-between gap-2">
									<div class="space-y-1">
										<h3 class="text-xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">Erasmushogeschool Brussel</h3>
										<p class="text-blue-600 dark:text-blue-400 font-semibold">Lecturer & Researcher</p>
									</div>
									<span class="text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">Sep 2020 – Sep 2024</span>
								</div>
								<p class="text-gray-700 dark:text-gray-300 leading-relaxed">
									Taught C# and the .NET stack (ASP.NET Core, Entity Framework, Identity Server) to graduate-track (HBO5) students.
									Also consulted on project-based courses, bringing real-world cases from industry into the curriculum.
									Contributed as researcher to the EU-funded PACE-VET project, developing a cross-platform certification app (Flutter/Dart) and Elixir/Phoenix API for the creative sector across European states.
								</p>
								<div class="flex flex-wrap gap-2 pt-1">
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">C#</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">ASP.NET</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Entity Framework</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Flutter</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Elixir</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Phoenix</span>
								</div>
							</div>
						</div>

						<!-- Acerta -->
						<div class="rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
							<div class="h-1 bg-gradient-to-r from-blue-500 to-purple-500"></div>
							<div class="p-6 space-y-3">
								<div class="flex flex-wrap items-start justify-between gap-2">
									<div class="space-y-1">
										<div class="flex items-center gap-2 flex-wrap">
											<h3 class="text-xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">Acerta</h3>
											<span class="px-2 py-0.5 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-xs rounded font-medium">via Euricom</span>
										</div>
										<p class="text-blue-600 dark:text-blue-400 font-semibold">Analyst Developer</p>
									</div>
									<span class="text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">Jul 2019 – Jul 2022</span>
								</div>
								<p class="text-gray-700 dark:text-gray-300 leading-relaxed">
									Core team on Acerta's Document Management System — a distributed, highly concurrent .NET system handling archival, generation, and distribution of millions of documents per year.
									Led development of the migration path to the Unified Post cloud platform, building tooling that migrated millions of documents per hour and a rule-based proxy server for request-by-request routing between legacy and new DMS.
								</p>
								<div class="flex flex-wrap gap-2 pt-1">
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">C#</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">.NET</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">Akka.NET</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">IBM WebSphere MQ</span>
									<span class="px-2.5 py-1 text-xs font-medium bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-400 rounded">SQL Server</span>
								</div>
							</div>
						</div>

						<!-- Camco -->
						<div class="rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
							<div class="h-1 bg-gradient-to-r from-blue-500 to-purple-500"></div>
							<div class="p-6 space-y-3">
								<div class="flex flex-wrap items-start justify-between gap-2">
									<div class="space-y-1">
										<h3 class="text-xl font-bold text-gray-900 dark:text-gray-100" style="font-family: 'Montserrat', sans-serif;">Camco Technologies</h3>
										<p class="text-blue-600 dark:text-blue-400 font-semibold">Full Stack Developer</p>
									</div>
									<span class="text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">Oct 2017 – Aug 2019</span>
