---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "About - Wannes";
const description = "Wannes — full-stack .NET consultant, founder of Elixus, building Meshum, the control plane for enterprise AI governance. Canonical About page in the Teal Square design language.";
---

<BaseLayout title={title} description={description}>
  <main class="flex-1">
    <div class="wrap">

      <!-- ============================ Header ============================ -->
      <header class="header">
        <p class="eyebrow"><span class="sq" aria-hidden="true"></span>about</p>
        <h1 class="header__name">Wannes</h1>
        <p class="header__role">
          Software Engineer <span class="sep" aria-hidden="true">/</span> AI Architect
        </p>
        <p class="header__intro">
          Full-stack .NET consultant building systems that scale — and founder of
          Elixus, where I'm currently building
          <a href="https://www.meshum.dev" rel="noopener noreferrer">Meshum</a>, the
          control plane that gives organizations one place to see, manage, and
          govern how their people use AI.
        </p>
        <hr class="gradient-rule" />
      </header>

      <!-- ============================ Bio ============================ -->
      <section class="section" aria-labelledby="bio-title">
        <p class="eyebrow"><span class="sq" aria-hidden="true"></span>bio</p>
        <div class="prose">
          <h2 id="bio-title" class="h-section">Who I am</h2>
          <p>
            I'm a full-stack .NET consultant with a deep passion for exploring new
            technologies and <em class="accent">building systems that scale</em>. My
            journey has taken me through Rust, Elixir, and modern web development —
            always seeking <em class="accent">the right tool for the job</em>.
          </p>
          <p>
            Outside of client work I teach C# and .NET at Erasmushogeschool Brussel.
            As the founder of Elixus, I'm currently building
            <a href="https://www.meshum.dev" rel="noopener noreferrer">Meshum</a> — a
            centralized platform that gives organizations visibility into their AI
            usage and lets them distribute and govern MCP tooling, skills, and
            agents across any vendor.
          </p>
        </div>
      </section>

      <!-- ============================ Focus ============================ -->
      <section class="section" aria-labelledby="focus-title">
        <p class="eyebrow"><span class="sq" aria-hidden="true"></span>focus</p>
        <h2 id="focus-title" class="h-section">What I work with</h2>
        <p style="color: var(--ts-muted); margin: 0 0 22px 0; max-width: 60ch; font-size: 15px;">
          Opinionated, but never dogmatic — picked because they fit the problem, not the hype.
        </p>
        <ul class="pills" role="list">
          <li><span class="pill">.NET</span></li>
          <li><span class="pill">Rust</span></li>
          <li><span class="pill">Elixir</span></li>
          <li><span class="pill">TypeScript</span></li>
          <li><span class="pill">PostgreSQL</span></li>
          <li><span class="pill">Redis</span></li>
          <li><span class="pill">React</span></li>
          <li><span class="pill">Blazor</span></li>
          <li><span class="pill">Azure</span></li>
        </ul>
      </section>

      <!-- ============================ Certifications ============================ -->
      <section class="section" aria-labelledby="cert-title">
        <p class="eyebrow"><span class="sq" aria-hidden="true"></span>certifications</p>
        <h2 id="cert-title" class="h-section">Credentials</h2>
        <article class="cert-card">
          <div class="cert-card__bar" aria-hidden="true"></div>
          <div class="cert-card__body">
            <a class="cert-badge" href="https://www.credly.com/badges/bda72065-fca1-40b5-a61b-a2a29c735264/public_url" target="_blank" rel="noopener noreferrer" aria-label="View CCAR-F credential on Credly">
              <div data-iframe-width="150" data-iframe-height="270" data-share-badge-id="bda72065-fca1-40b5-a61b-a2a29c735264" data-share-badge-host="https://www.credly.com"></div>
              <script is:inline async src="//cdn.credly.com/assets/utilities/embed.js"></script>
            </a>
            <div class="cert-info">
              <div class="cert-pills">
                <span class="cert-pill cert-pill--brand">CCAR-F</span>
                <span class="cert-pill">938 / 1000</span>
              </div>
              <p class="cert-issuer">Anthropic</p>
              <h3 class="cert-name">Claude Certified Architect – Foundations</h3>
              <a class="cert-verify" href="https://www.credly.com/badges/bda72065-fca1-40b5-a61b-a2a29c735264/public_url" target="_blank" rel="noopener noreferrer">
                Verify credential
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>
        </article>
      </section>

      <!-- ============================ Experience ============================ -->
      <section class="section" aria-labelledby="exp-title">
        <p class="eyebrow"><span class="sq" aria-hidden="true"></span>experience</p>
        <h2 id="exp-title" class="h-section">Where I've worked</h2>
        <ol class="timeline" role="list">

          <li class="role-item">
            <span class="node" aria-hidden="true"></span>
            <article class="role-card">
              <div class="role-head">
                <div>
                  <div class="role-company-row">
                    <h3 class="role-company">Twipe</h3>
                    <span class="via-tag">via Euricom</span>
                  </div>
                  <p class="role-title">Senior Backend Developer</p>
                </div>
                <span class="role-dates">Feb 2026 — Present</span>
              </div>
              <p class="role-desc">
                Backend development at Twipe, a digital publishing platform powering
                e-editions and reading apps for major media companies across Europe.
              </p>
              <div class="tech-tags">
                <span class="tech-tag">.NET</span>
                <span class="tech-tag">C#</span>
              </div>
            </article>
          </li>

          <li class="role-item">
            <span class="node" aria-hidden="true"></span>
            <article class="role-card">
              <div class="role-head">
                <div>
                  <div class="role-company-row">
                    <h3 class="role-company">Euricom</h3>
                  </div>
                  <p class="role-title">Software Consultant</p>
                </div>
                <span class="role-dates">Oct 2025 — Jan 2026</span>
              </div>
              <p class="role-desc">
                Rebuilt Euricom's internal sales dashboard from scratch after an
                intern-built version developed significant issues. Chose .NET Blazor
                Server with .NET Aspire and set up a full CI/CD pipeline deploying
                automatically to Azure container apps.
              </p>
              <div class="tech-tags">
                <span class="tech-tag">Blazor</span>
                <span class="tech-tag">.NET Aspire</span>
                <span class="tech-tag">Azure</span>
                <span class="tech-tag">Tailwind</span>
              </div>
            </article>
          </li>

          <li class="role-item">
            <span class="node" aria-hidden="true"></span>
            <article class="role-card">
              <div class="role-head">
                <div>
                  <div class="role-company-row">
                    <h3 class="role-company">Agilitas Belgium</h3>
                    <span class="via-tag">via Euricom</span>
                  </div>
                  <p class="role-title">Lead Developer</p>
                </div>
                <span class="role-dates">Jul 2022 — Sep 2024</span>
              </div>
              <p class="role-desc">
                Brought in to migrate legacy PHP customer portals and rebuild all
                group websites across Agilitas and its European branches (Amplo,
                Ascento, Luba, E&amp;A). Responsible for the full migration,
                stakeholder communication, and requirement gathering. When
                additional developers were onboarded, led the team and managed SCRUM
                processes. Built the new platform on Umbraco CMS with Azure
                monitoring and a job board featuring location-aware faceted search
                with Blazor Server.
              </p>
              <div class="tech-tags">
                <span class="tech-tag">C#</span>
                <span class="tech-tag">Umbraco</span>
                <span class="tech-tag">ASP.NET Core</span>
                <span class="tech-tag">Blazor</span>
                <span class="tech-tag">Azure</span>
                <span class="tech-tag">PHP</span>
                <span class="tech-tag">Vue</span>
              </div>
            </article>
          </li>

          <li class="role-item">
            <span class="node" aria-hidden="true"></span>
            <article class="role-card">
              <div class="role-head">
                <div>
                  <div class="role-company-row">
                    <h3 class="role-company">Erasmushogeschool Brussel</h3>
                  </div>
                  <p class="role-title">Lecturer &amp; Researcher</p>
                </div>
                <span class="role-dates">Sep 2020 — Sep 2024</span>
              </div>
              <p class="role-desc">
                Taught C# and the .NET stack (ASP.NET Core, Entity Framework,
                Identity Server) to graduate-track (HBO5) students. Also consulted
                on project-based courses, bringing real-world cases from industry
                into the curriculum. Contributed as researcher to the EU-funded
                PACE-VET project, developing a cross-platform certification app
                (Flutter/Dart) and Elixir/Phoenix API for the creative sector across
                European states.
              </p>
              <div class="tech-tags">
                <span class="tech-tag">C#</span>
                <span class="tech-tag">ASP.NET</span>
                <span class="tech-tag">Entity Framework</span>
                <span class="tech-tag">Flutter</span>
                <span class="tech-tag">Elixir</span>
                <span class="tech-tag">Phoenix</span>
              </div>
            </article>
          </li>

          <li class="role-item">
            <span class="node" aria-hidden="true"></span>
            <article class="role-card">
              <div class="role-head">
                <div>
                  <div class="role-company-row">
                    <h3 class="role-company">Acerta</h3>
                    <span class="via-tag">via Euricom</span>
                  </div>
                  <p class="role-title">Analyst Developer</p>
                </div>
                <span class="role-dates">Jul 2019 — Jul 2022</span>
              </div>
              <p class="role-desc">
                Core team on Acerta's Document Management System — a distributed,
                highly concurrent .NET system handling archival, generation, and
                distribution of millions of documents per year. Led development of
                the migration path to the Unified Post cloud platform, building
                tooling that migrated millions of documents per hour and a
                rule-based proxy server for request-by-request routing between
                legacy and new DMS.
              </p>
              <div class="tech-tags">
                <span class="tech-tag">C#</span>
                <span class="tech-tag">.NET</span>
                <span class="tech-tag">Akka.NET</span>
                <span class="tech-tag">IBM WebSphere MQ</span>
                <span class="tech-tag">SQL Server</span>
              </div>
            </article>
          </li>

        </ol>
      </section>

      <!-- ============================ Connect ============================ -->
      <section class="section" aria-labelledby="connect-title">
        <p class="eyebrow"><span class="sq" aria-hidden="true"></span>connect</p>
        <h2 id="connect-title" class="h-section">Say hello</h2>
        <p style="color: var(--ts-muted); margin: 0 0 22px 0; max-width: 60ch; font-size: 15px;">
          Always glad to talk shop — systems, teaching, or whatever you're building.
        </p>
        <ul class="connect-grid" role="list">
          <li>
            <a class="connect-link" href="https://github.com/dealloc" rel="noopener noreferrer">
              <span>GitHub<span class="handle">/ dealloc</span></span>
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4.5 11.5 L11.5 4.5" /><path d="M6 4.5 H11.5 V10" />
              </svg>
            </a>
          </li>
          <li>
            <a class="connect-link" href="#">
              <span>LinkedIn</span>
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4.5 11.5 L11.5 4.5" /><path d="M6 4.5 H11.5 V10" />
              </svg>
            </a>
          </li>
          <li>
            <a class="connect-link" href="/blogs">
              <span>Blog<span class="handle">/ writing</span></span>
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4.5 11.5 L11.5 4.5" /><path d="M6 4.5 H11.5 V10" />
              </svg>
            </a>
          </li>
          <li>
            <a class="connect-link" href="https://www.elixus.be" rel="noopener noreferrer">
              <span>Elixus<span class="handle">/ the company</span></span>
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4.5 11.5 L11.5 4.5" /><path d="M6 4.5 H11.5 V10" />
              </svg>
            </a>
          </li>
        </ul>
      </section>

    </div>
  </main>
</BaseLayout>

<style>
  /* ============================================================
     Teal Square — About page component styles.
     Design tokens (--ts-*) are defined globally in global.css.
     ============================================================ */

  a {
    color: var(--ts-accent-text);
    text-decoration: underline;
    text-decoration-color: oklch(62% 0.08 165 / 0.42);
    text-underline-offset: 3px;
    transition: color 160ms ease, text-decoration-color 160ms ease;
  }
  a:hover { color: var(--ts-primary); text-decoration-color: var(--ts-primary); }
  a:focus-visible { outline: 2px solid var(--ts-primary); outline-offset: 3px; border-radius: 3px; }

  .wrap { max-width: var(--ts-maxw); margin: 0 auto; padding: 0 24px; }

  /* ============================================================
     Signature: the teal square + mono eyebrow
     ============================================================ */
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--ts-font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ts-muted);
    margin: 0 0 16px 0;
  }
  .eyebrow .sq {
    width: 7px;
    height: 7px;
    background: var(--ts-primary);
    flex: none;
  }

  .h-section {
    font-family: var(--ts-font-heading);
    font-weight: 600;
    letter-spacing: -0.02em;
    font-size: clamp(24px, 3vw, 30px);
    line-height: 1.15;
    margin: 0 0 20px 0;
    color: var(--ts-foreground);
  }

  /* ============================================================
     Header — typographic, NO blob. Thin gradient rule = the one
     restrained brand-gradient moment.
     ============================================================ */
  .header { padding: clamp(48px, 8vw, 80px) 0 clamp(28px, 4vw, 40px); }
  .header__name {
    font-family: var(--ts-font-heading);
    font-weight: 700;
    font-size: clamp(46px, 9vw, 80px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ts-foreground);
  }
  .header__role {
    margin: 16px 0 0 0;
    font-size: clamp(17px, 2vw, 19px);
    color: var(--ts-muted);
    font-weight: 400;
  }
  .header__role .sep { color: var(--ts-primary); margin: 0 10px; font-weight: 600; }
  .header__intro {
    max-width: 62ch;
    margin: 24px 0 0 0;
    font-size: clamp(17px, 2vw, 19px);
    line-height: 1.62;
    font-weight: 300;
    color: var(--ts-foreground);
  }
  .gradient-rule {
    height: 2px;
    border: 0;
    margin: clamp(36px, 5vw, 52px) 0 0 0;
    background: linear-gradient(90deg, var(--ts-primary), var(--ts-accent) 70%, transparent);
    border-radius: 2px;
  }

  /* ============================================================
     Sections — single column, hairline dividers, NO numbers
     ============================================================ */
  .section {
    padding: clamp(40px, 6vw, 64px) 0;
    border-top: 1px solid var(--ts-border-subtle);
  }

  /* ============================================================
     Bio prose
     ============================================================ */
  .prose p {
    font-size: 17px;
    line-height: 1.68;
    margin: 0 0 1.2em;
    color: var(--ts-foreground);
    max-width: 62ch;
  }
  .prose p:last-child { margin-bottom: 0; }
  .prose em.accent {
    font-style: normal;
    font-family: var(--ts-font-heading);
    font-weight: 500;
    color: var(--ts-foreground);
  }

  /* ============================================================
     Certifications — real Credly badge + verify link
     ============================================================ */
  .cert-card {
    border: 1px solid var(--ts-border-subtle);
    border-radius: 12px;
    overflow: hidden;
    background: var(--ts-surface);
    box-shadow: var(--ts-shadow-sm);
  }
  .cert-card__bar {
    height: 3px;
    background: linear-gradient(90deg, var(--ts-primary), var(--ts-accent));
  }
  .cert-card__body {
    padding: 28px;
    display: flex;
    gap: 26px;
    align-items: flex-start;
  }
  .cert-badge {
    flex: none;
    width: 150px;
    display: block;
    text-decoration: none;
  }
  .cert-info { flex: 1; min-width: 0; }
  .cert-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }
  .cert-pill {
    font-family: var(--ts-font-mono);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 3px 9px;
    border-radius: 5px;
    border: 1px solid var(--ts-border);
    background: var(--ts-elevated);
    color: var(--ts-foreground);
  }
  /* Brand pill: dark slate bg + white text — passes AA in both themes */
  .cert-pill--brand {
    background: var(--ts-accent);
    border-color: var(--ts-accent);
    color: oklch(98% 0.005 220);
  }
  .cert-issuer {
    font-family: var(--ts-font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ts-muted);
    margin: 0 0 6px 0;
  }
  .cert-name {
    font-family: var(--ts-font-heading);
    font-weight: 600;
    font-size: 19px;
    letter-spacing: -0.01em;
    line-height: 1.25;
    margin: 0 0 14px 0;
    color: var(--ts-foreground);
  }
  .cert-verify {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--ts-font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--ts-accent-text);
    text-decoration: none;
    border-bottom: 1px solid oklch(62% 0.08 165 / 0.4);
    padding-bottom: 1px;
    transition: color 160ms ease, border-color 160ms ease;
  }
  .cert-verify:hover { color: var(--ts-primary); border-bottom-color: var(--ts-primary); text-decoration: none; }
  .cert-verify svg { flex: none; }

  /* ============================================================
     Focus — simple teal-bordered pills
     ============================================================ */
  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    max-width: 680px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    padding: 6px 13px;
    border: 1px solid var(--ts-border);
    border-radius: 6px;
    background: var(--ts-surface);
    color: var(--ts-foreground);
    font-family: var(--ts-font-mono);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: border-color 160ms ease, background 160ms ease;
  }
  .pill:hover {
    border-color: var(--ts-primary);
    background: oklch(62% 0.08 165 / 0.06);
  }

  /* ============================================================
     Experience — vertical timeline (rail + nodes + cards)
     ============================================================ */
  .timeline { position: relative; list-style: none; margin: 8px 0 0 0; padding: 0; }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--ts-primary);
    opacity: 0.45;
    border-radius: 2px;
  }
  .role-item {
    position: relative;
    padding-left: 40px;
    padding-bottom: 18px;
    list-style: none;
  }
  .role-item:last-child { padding-bottom: 0; }
  .node {
    position: absolute;
    left: 0;
    top: 4px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--ts-page);
    border: 2px solid var(--ts-primary);
    display: grid;
    place-items: center;
    z-index: 1;
  }
  .node::after {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--ts-primary);
  }
  .role-card {
    padding: 18px 20px;
    background: var(--ts-surface);
    border: 1px solid var(--ts-border-subtle);
    border-radius: 10px;
    box-shadow: var(--ts-shadow-sm);
    transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .role-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--ts-shadow-md);
      border-color: var(--ts-border);
    }
  }
  .role-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 4px 14px;
  }
  .role-company-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .role-company {
    font-family: var(--ts-font-heading);
    font-weight: 600;
    font-size: 20px;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ts-foreground);
  }
  .via-tag {
    font-family: var(--ts-font-mono);
    font-size: 11px;
    padding: 2px 7px;
    border: 1px solid var(--ts-border-subtle);
    border-radius: 4px;
    background: var(--ts-elevated);
    color: var(--ts-muted);
  }
  .role-dates {
    font-family: var(--ts-font-mono);
    font-size: 12.5px;
    color: var(--ts-muted);
    white-space: nowrap;
  }
  .role-title {
    margin: 4px 0 0 0;
    font-size: 14.5px;
    font-weight: 500;
    color: var(--ts-muted);
  }
  .role-desc {
    margin: 10px 0 0 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ts-muted);
  }
  .tech-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
  .tech-tag {
    font-family: var(--ts-font-mono);
    font-size: 11.5px;
    padding: 3px 8px;
    border: 1px solid var(--ts-border-subtle);
    border-radius: 4px;
    background: var(--ts-elevated);
    color: var(--ts-muted);
  }

  /* ============================================================
     Connect — "Say hello" grid of cards (Studio layout)
     ============================================================ */
  .connect-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 14px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .connect-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
