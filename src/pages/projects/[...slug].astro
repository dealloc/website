---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from "../../components/Prose.astro";
import ScrollProgressBar from "../../components/ScrollProgressBar.astro";

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}
type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await render(project);

const { title, description, startDate, endDate, status, technologies, heroImage, githubUrl, liveUrl, sponsorUrl } = project.data;

const isActive = status === 'active';
---

<BaseLayout title={title} description={description} image={heroImage}>
	<ScrollProgressBar />
	<main class="flex-1 project">
		<article class="container">
			<!-- Back link -->
			<a class="back-link" href="/projects">← back to projects</a>

			<!-- Hero Image (if present) -->
			{heroImage && (
				<img class="hero" src={heroImage} alt={title} />
			)}

			<!-- Project Header -->
			<header class="head">
				<h1 class="title">{title}</h1>

				{description && (
					<p class="lede">{description}</p>
				)}

				<!-- Metadata block -->
				<div class="meta">
					<span class:list={['status', { 'status--active': isActive }]}>
						{status.charAt(0).toUpperCase() + status.slice(1)}
					</span>
					<span class="dates">
						{startDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
						{endDate && ` - ${endDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}`}
					</span>
				</div>

				<!-- Technologies -->
				{technologies && technologies.length > 0 && (
					<ul class="tags" role="list">
						{technologies.map((tech) => (
							<li class="tag">{tech}</li>
						))}
					</ul>
				)}

				<!-- Action buttons -->
				{(githubUrl || liveUrl || sponsorUrl) && (
					<div class="actions">
						{githubUrl && (
							<a class="btn btn--outline" href={githubUrl} target="_blank" rel="noopener noreferrer">
								<svg class="btn__icon" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
								</svg>
								View on GitHub
							</a>
						)}
						{liveUrl && (
							<a class="btn btn--filled" href={liveUrl} target="_blank" rel="noopener noreferrer">
								<svg class="btn__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
								</svg>
								View Live
							</a>
						)}
						{sponsorUrl && (
							<a class="btn btn--outline" href={sponsorUrl} target="_blank" rel="noopener noreferrer">
								<svg class="btn__icon btn__icon--accent" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
									<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
								</svg>
								Sponsor
							</a>
						)}
					</div>
				)}
			</header>

			<!-- Project Content -->
			<Prose>
				<Content />
			</Prose>

			<!-- Back to Projects link -->
			<footer class="proj-footer">
				<a class="back-link" href="/projects">← back to all projects</a>
			</footer>
		</article>
	</main>
</BaseLayout>

<style>
	.project .container {
		max-width: var(--ts-maxw);
		margin: 0 auto;
		padding: clamp(40px, 6vw, 64px) 24px clamp(48px, 8vw, 80px);
	}

	/* Back link — mono, teal */
	.back-link {
		display: inline-block;
		font-family: var(--ts-font-mono);
		font-size: 13px;
		font-weight: 500;
		color: var(--ts-accent-text);
		text-decoration: none;
		border-bottom: 1px solid oklch(62% 0.08 165 / 0.4);
		padding-bottom: 1px;
		transition: color 160ms ease, border-color 160ms ease;
	}
	.back-link:hover {
		color: var(--ts-primary);
		border-bottom-color: var(--ts-primary);
	}
	.back-link:focus-visible {
		outline: 2px solid var(--ts-primary);
		outline-offset: 3px;
		border-radius: 3px;
	}

	/* Hero image */
	.hero {
		border-radius: 8px;
		max-width: 100%;
		height: auto;
		margin: 28px 0 24px;
		display: block;
	}

	/* Header */
	.head {
		margin-bottom: 40px;
	}
	.title {
		font-family: var(--ts-font-heading);
		font-weight: 700;
		font-size: clamp(32px, 5vw, 52px);
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--ts-foreground);
		margin: 0 0 16px;
	}
	.lede {
		font-family: var(--ts-font-body);
		font-size: 20px;
		line-height: 1.6;
		color: var(--ts-muted);
		margin: 0 0 28px;
		max-width: 62ch;
	}

	/* Metadata block — teal accent bar */
	.meta {
		border-left: 3px solid var(--ts-primary);
		padding-left: 14px;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 12px;
		margin-bottom: 24px;
	}

	/* Status badge — teal-tinted for active, muted otherwise */
	.status {
		display: inline-flex;
		align-items: center;
		font-family: var(--ts-font-mono);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.02em;
		padding: 3px 9px;
		border-radius: 5px;
		border: 1px solid var(--ts-border);
		background: var(--ts-elevated);
		color: var(--ts-muted);
		text-transform: capitalize;
	}
	.status--active {
		background: oklch(62% 0.08 165 / 0.10);
		border-color: oklch(62% 0.08 165 / 0.45);
		color: var(--ts-accent-text);
	}

	.dates {
		font-family: var(--ts-font-mono);
		font-size: 12.5px;
		color: var(--ts-muted);
	}

	/* Tech tags — teal-bordered mono pills */
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		list-style: none;
		padding: 0;
		margin: 0 0 28px;
	}
	.tag {
		font-family: var(--ts-font-mono);
		font-size: 13px;
		font-weight: 500;
		padding: 6px 13px;
		border: 1px solid var(--ts-border);
		border-radius: 6px;
		background: var(--ts-surface);
		color: var(--ts-foreground);
		transition: border-color 160ms ease, background 160ms ease;
	}
	@media (prefers-reduced-motion: no-preference) {
		.tag:hover {
			border-color: var(--ts-primary);
			background: oklch(62% 0.08 165 / 0.06);
		}
	}

	/* Action buttons */
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
	}
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-family: var(--ts-font-body);
		font-size: 14px;
		font-weight: 500;
		border-radius: 8px;
		padding: 10px 16px;
		text-decoration: none;
		transition: border-color 160ms ease, background 160ms ease, opacity 160ms ease;
	}
	.btn:focus-visible {
		outline: 2px solid var(--ts-primary);
		outline-offset: 3px;
	}
	.btn__icon {
		width: 18px;
		height: 18px;
		flex: none;
	}
	.btn__icon--accent {
		color: var(--ts-accent-text);
	}

	/* Outline button — surface + border + foreground text */
	.btn--outline {
		background: var(--ts-surface);
		border: 1px solid var(--ts-border);
		color: var(--ts-foreground);
	}
	@media (prefers-reduced-motion: no-preference) {
		.btn--outline:hover {
			border-color: var(--ts-primary);
		}
	}

	/* Filled button — dark slate bg + white text (passes AA) */
	.btn--filled {
		background: var(--ts-accent);
		border: 1px solid var(--ts-accent);
		color: oklch(98% 0.005 220);
	}
	@media (prefers-reduced-motion: no-preference) {
		.btn--filled:hover {
			opacity: 0.88;
		}
	}

	/* Footer back link */
	.proj-footer {
		margin-top: 48px;
		padding-top: 28px;
		border-top: 1px solid var(--ts-border-subtle);
	}
</style>
