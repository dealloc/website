---
---

<div id="cookie-banner" class="cookie-banner hidden">
	<div class="cookie-banner-content">
		<div class="cookie-banner-inner">
			<div class="cb-row">
				<div class="cb-text">
					<h3>We value your privacy</h3>
					<p>
						This website uses Microsoft Clarity to understand how visitors interact with our site through anonymous usage analytics. By accepting, you consent to the collection of this data. We do not collect personally identifiable information or share your data with third parties beyond Microsoft's analytics service. You can decline and still use the website normally.
					</p>
				</div>
				<div class="cb-actions">
					<button id="cookie-decline" class="btn-secondary">Decline</button>
					<button id="cookie-accept" class="btn-primary">Accept</button>
				</div>
			</div>
		</div>
	</div>
</div>

<style>
	.cookie-banner {
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 9999;
		padding: 1rem;
		animation: slideUp 0.3s ease-out;
		max-width: 100vw;
		overflow-x: hidden;
	}

	.cookie-banner.hidden { display: none; }

	.cookie-banner-content { max-width: 880px; margin: 0 auto; width: 100%; }

	.cookie-banner-inner {
		position: relative;
		padding: 1.5rem;
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		background: color-mix(in oklch, var(--ts-surface) 92%, transparent);
		border: 1px solid var(--ts-border);
		border-radius: 12px;
		box-shadow: var(--ts-shadow-md);
	}

	.cb-row {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	@media (min-width: 640px) {
		.cb-row { flex-direction: row; align-items: center; justify-content: space-between; }
	}

	.cb-text h3 {
		font-family: var(--ts-font-heading);
		font-weight: 600;
		font-size: 1.125rem;
		margin: 0 0 0.5rem 0;
		color: var(--ts-foreground);
	}
	.cb-text p {
		font-size: 0.875rem;
		line-height: 1.5;
		color: var(--ts-muted);
		margin: 0;
	}

	.cb-actions { display: flex; gap: 0.75rem; flex-shrink: 0; }

	.btn-primary {
		background: var(--ts-accent);
		color: oklch(98% 0.005 220);
		border: none;
		padding: 0.5rem 1.5rem;
		border-radius: 8px;
		font-family: var(--ts-font-body);
		font-weight: 500;
		font-size: 0.875rem;
		cursor: pointer;
		transition: opacity 160ms ease;
	}
	.btn-primary:hover { opacity: 0.88; }

	.btn-secondary {
		background: transparent;
		border: 1px solid var(--ts-border);
		color: var(--ts-muted);
		padding: 0.5rem 1.5rem;
		border-radius: 8px;
		font-family: var(--ts-font-body);
		font-weight: 500;
		font-size: 0.875rem;
		cursor: pointer;
		transition: background 160ms ease, color 160ms ease;
	}
	.btn-secondary:hover { background: var(--ts-elevated); color: var(--ts-foreground); }

	@keyframes slideUp {
		from { transform: translateY(100%); opacity: 0; }
		to { transform: translateY(0); opacity: 1; }
	}

	@media (max-width: 640px) {
		.cookie-banner-inner { padding: 1rem; }
	}
</style>

<script>
	// Check if user has already made a choice
	const CONSENT_KEY = 'cookie-consent';

	function getCookieConsent() {
		return localStorage.getItem(CONSENT_KEY);
	}

	function setCookieConsent(value: 'accepted' | 'declined') {
		localStorage.setItem(CONSENT_KEY, value);
		window.dispatchEvent(new CustomEvent('cookieConsentChange', { detail: { consent: value } }));
	}

	function showBanner() {
		const banner = document.getElementById('cookie-banner');
		if (banner) {
			banner.classList.remove('hidden');
		}
	}

	function hideBanner() {
		const banner = document.getElementById('cookie-banner');
		if (banner) {
			banner.classList.add('hidden');
		}
	}

	// Show banner if no consent has been given
	const consent = getCookieConsent();
	if (!consent) {
		showBanner();
	}

	// Handle accept button
	const acceptBtn = document.getElementById('cookie-accept');
	acceptBtn?.addEventListener('click', () => {
		setCookieConsent('accepted');
		hideBanner();
		// Reload to activate tracking scripts
		window.location.reload();
	});

	// Handle decline button
	const declineBtn = document.getElementById('cookie-decline');
	declineBtn?.addEventListener('click', () => {
		setCookieConsent('declined');
		hideBanner();
	});

	// Export function for other scripts to check consent
	(window as any).hasAnalyticsConsent = function() {
		return getCookieConsent() === 'accepted';
	};
</script>
