---

<div class="prose prose-lg max-w-none">
	<slot></slot>
</div>

<style is:global>
	/* ============================================================
	   Prose — Teal Square
	   Global styles override the typography plugin's :where() defaults.
	   ============================================================ */
	.prose {
		color: var(--ts-foreground);
		font-family: var(--ts-font-body);
		line-height: 1.7;
	}

	.prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6 {
		font-family: var(--ts-font-heading);
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--ts-foreground);
	}
	.prose h1 { font-size: 2.25rem; margin: 3rem 0 1.5rem; line-height: 1.15; }
	.prose h2 { font-size: 1.875rem; margin: 2.5rem 0 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--ts-border-subtle); line-height: 1.2; }
	.prose h3 { font-size: 1.5rem; margin: 2rem 0 0.75rem; line-height: 1.25; }
	.prose h4 { font-size: 1.25rem; margin: 1.5rem 0 0.5rem; font-weight: 500; }
	.prose h5 { font-size: 1.125rem; margin: 1.25rem 0 0.5rem; font-weight: 500; color: var(--ts-muted); }
	.prose h6 { font-size: 1rem; margin: 1rem 0 0.5rem; font-weight: 500; color: var(--ts-muted); }

	.prose p { margin: 0 0 1.25em; font-size: 1.0625rem; }

	.prose a {
		color: var(--ts-accent-text);
		text-decoration: underline;
		text-decoration-color: oklch(62% 0.08 165 / 0.4);
		text-underline-offset: 3px;
		font-weight: 500;
		transition: color 160ms ease, text-decoration-color 160ms ease;
	}
	.prose a:hover { color: var(--ts-primary); text-decoration-color: var(--ts-primary); }

	.prose strong { color: var(--ts-foreground); font-weight: 600; }
	.prose em { color: var(--ts-foreground); }

	/* Inline code — foreground text for AA; teal reserved for links/large */
	.prose code {
		font-family: var(--ts-font-mono);
		font-size: 0.9em;
		background: var(--ts-elevated);
		border: 1px solid var(--ts-border-subtle);
		padding: 0.15em 0.4em;
		border-radius: 4px;
		color: var(--ts-foreground);
	}
	/* Code blocks — dark technical surface in both themes */
	.prose pre {
		background: oklch(19% 0.02 220);
		border: 1px solid var(--ts-border);
		border-radius: 8px;
		padding: 1.25rem 1.5rem;
		margin: 1.5rem 0;
		overflow-x: auto;
	}
	.prose pre code {
		background: transparent;
		border: none;
		padding: 0;
		color: oklch(92% 0.005 220);
		font-size: 0.875rem;
		line-height: 1.55;
	}

	.prose blockquote {
		border-left: 3px solid var(--ts-primary);
		background: var(--ts-elevated);
		padding: 0.75rem 1.5rem;
		margin: 1.5rem 0;
		border-radius: 0 6px 6px 0;
		font-style: normal;
	}
	.prose blockquote p { color: var(--ts-muted); margin: 0.5em 0; }

	.prose ul, .prose ol { margin: 1.5rem 0; padding-left: 1.5rem; }
	.prose ul { list-style: disc; }
	.prose ol { list-style: decimal; }
	.prose li { margin: 0.4rem 0; color: var(--ts-foreground); }
	.prose li::marker { color: var(--ts-primary); }

	.prose img { border-radius: 8px; margin: 1.5rem 0; max-width: 100%; height: auto; }
	.prose hr { border: none; border-top: 1px solid var(--ts-border-subtle); margin: 2.5rem 0; }

	.prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.95rem; }
	.prose th {
		background: var(--ts-elevated);
		font-family: var(--ts-font-heading);
		font-weight: 600;
		text-align: left;
		padding: 0.6rem 0.75rem;
		border: 1px solid var(--ts-border);
		color: var(--ts-foreground);
	}
	.prose td { padding: 0.6rem 0.75rem; border: 1px solid var(--ts-border); color: var(--ts-muted); }

	/* Keyboard keys */
	.prose kbd {
		display: inline-block;
		padding: 0.125rem 0.5rem;
		font-family: var(--ts-font-mono);
		font-size: 0.875em;
		font-weight: 500;
		line-height: 1.5;
		color: var(--ts-foreground);
		background-color: var(--ts-elevated);
		border: 1px solid var(--ts-border);
		border-radius: 0.375rem;
		box-shadow: 0 1px 0 var(--ts-border);
	}

	/* Highlighted/marked text — keep amber for highlight semantics */
	.prose mark {
		padding: 0.125rem 0.25rem;
		background-color: oklch(90% 0.15 85);
		color: oklch(20% 0.01 220);
		border-radius: 0.25rem;
	}
	@media (prefers-color-scheme: dark) {
		.prose mark {
			background-color: oklch(45% 0.15 85);
			color: oklch(97% 0.01 220);
		}
	}

	/* Abbreviations */
	.prose abbr {
		text-decoration: underline dotted;
		text-decoration-color: var(--ts-muted);
		text-underline-offset: 3px;
		cursor: help;
	}
</style>
